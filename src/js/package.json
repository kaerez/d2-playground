  "name": "d2-playground-static",
  "version": "1.0.0",
  "description": "Pure SPA D2 Playground (Bun/Wasm/Un-hashed Optimized)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:executables": "bun build ../../server.ts --compile --target=bun-linux-x64 --outfile=../../dist-bin/d2-playground-linux-x64 && bun build ../../server.ts --compile --target=bun-linux-arm64 --outfile=../../dist-bin/d2-playground-linux-arm64 && bun build ../../server.ts --compile --target=bun-linux-x64-baseline --outfile=../../dist-bin/d2-playground-linux-x64-baseline && bun build ../../server.ts --compile --target=bun-linux-x64-musl --outfile=../../dist-bin/d2-playground-linux-x64-musl && bun build ../../server.ts --compile --target=bun-linux-arm64-musl --outfile=../../dist-bin/d2-playground-linux-arm64-musl && bun build ../../server.ts --compile --target=bun-windows-x64 --outfile=../../dist-bin/d2-playground-win-x64.exe && bun build ../../server.ts --compile --target=bun-darwin-arm64 --outfile=../../dist-bin/d2-playground-mac-arm64 && bun build ../../server.ts --compile --target=bun-darwin-x64 --outfile=../../dist-bin/d2-playground-mac-x64"
  },
  "dependencies": {
    "@terrastruct/d2": "^0.1.33",
    "monaco-editor": "^0.34.1",
    "shiki": "^0.11.1",
    "vscode-oniguruma": "^1.7.0",
    "vscode-textmate": "^8.0.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vite-plugin-monaco-editor": "latest"
  }
}
