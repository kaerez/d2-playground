name: Build Binaries, Create Release & Deploy Pages

on:
  push:
    branches: ["main", "master"]
  workflow_dispatch:

permissions:
  contents: write
  pages: write
  id-token: write

concurrency:
  group: "release-and-pages"
  cancel-in-progress: true

jobs:
  build-compile-release:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Source Code
        uses: actions/checkout@v4

      - name: Instantiate Bun Environment
        uses: oven-sh/setup-bun@v1
        with:
          bun-version: latest

      - name: Run Dependency Installation
        run: |
          cd src/js
          bun install

      - name: Execute Plugin Optimized Vite Production Build
        run: |
          cd src/js
          bun run build

      - name: Cross-Compile Standalone Platform Binaries
        run: |
          mkdir dist-bin
          cd src/js
          bun run build:executables

      - name: Package Executables with Assets into ZIP bundles
        run: |
          mkdir release-packages
          
          # Bundle the local cross-compiled files together with their corresponding static client assets
          cd dist-bin
          for binfile in *; do
            mkdir -p "temp_package/src/js"
            cp "$binfile" "temp_package/"
            cp -r "../src/js/dist" "temp_package/src/js/dist"
            cp "../server.ts" "temp_package/"
            
            zip -r "../release-packages/${binfile}-standalone.zip" temp_package/*
            rm -rf temp_package
          done

      - name: Generate Unique Version Tag
        id: tagger
        run: |
          TAG_VERSION="v1.0.$(date +'%Y%m%d%H%M%S')"
          echo "RELEASE_TAG=${TAG_VERSION}" >> $GITHUB_ENV
          echo "tag_name=${TAG_VERSION}" >> $GITHUB_OUTPUT

      - name: Publish Binaries to GitHub Releases
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ env.RELEASE_TAG }}
          name: "D2 Playground Offline Bundle ${{ env.RELEASE_TAG }}"
          body: "Automated production deployment containing compiled standalone local executable server bundles for Windows, Linux, and macOS."
          draft: false
          prerelease: false
          files: release-packages/*.zip
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Upload Core Site Artifacts to GitHub Pages Pipeline
        uses: actions/upload-pages-artifact@v3
        with:
          path: './src/js/dist'

  publish-pages:
    needs: build-compile-release
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Execute Live Static Site Deployment
        id: deployment
        uses: actions/deploy-pages@v4
